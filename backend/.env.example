# ── Server
HOST=0.0.0.0
PORT=8080

# ── Database
DATABASE_URL=postgres://tiketku:tiketku@localhost:5432/tiketku

# ── Redis
REDIS_URL=redis://127.0.0.1:6379

# ── JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars
JWT_EXPIRY_HOURS=24

# ── CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Security
BCRYPT_COST=12

# ── Logging
RUST_LOG=tiketku_api=debug,tower_http=info
